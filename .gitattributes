# Git attributes for consistent line endings across platforms

# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Config files
*.env text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary files
*.pyc binary
*.pyo binary
*.db binary
*.sqlite binary
*.exe binary
*.so binary
